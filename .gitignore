# Gitignore settings for ESPHome
# This is an example and may include too much for your use-case.
# You can modify this file to suit your needs.
/.esphome/
**/.esphome/
/secrets.yaml
.DS_Store
.worktrees/

# PCB fab: keep the (text) Gerbers/drill/CPL/BOM; the upload zip is regenerable
pcb/*/fabrication/*.zip
