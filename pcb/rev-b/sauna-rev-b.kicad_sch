  (text_box "High-temp loop: +24V_SAFE leaves J_SRL250 OUT, returns as SRL250_RTN, then feeds COIL+ on J_COIL. GPIO35 senses SRL250_RTN."
    (at 163 147 0) (size 155 17)
    (stroke (width 0.12) (type default) (color 0 0 0 0))
    (fill (type none))
    (effects (font (size 1.05 1.05)))
    (uuid 71ac0990-a24f-54ef-9fbf-4e324c9f630f)
  )
  (text_box "Relay monitor uses a 24 V wetting loop through the contactor 13/14 aux contact. Opto output pulls GPIO34 low when active."
    (at 338 143 0) (size 160 14)
    (stroke (width 0.12) (type default) (color 0 0 0 0))
    (fill (type none))
    (effects (font (size 1.05 1.05)))
    (uuid a95faf92-9e9d-5e3f-86d4-7b7d8cb8c43f)
  )
  (text_box "AUX output is a protected 24 V low-side switch on GPIO4. Leave GPIO4 unconfigured if unused."
    (at 338 126 0) (size 160 12)
    (stroke (width 0.12) (type default) (color 0 0 0 0))
    (fill (type none))
    (effects (font (size 1.05 1.05)))
    (uuid 6f3296fc-2136-52c9-bf8e-e27aa867a133)
  )
  (text_box "Use Espressif ESP32-DevKitC V4 with WROOM-32E/32D. Do not use WROVER: Rev B uses GPIO16/GPIO17."
    (at 418 392 0) (size 145 11)
    (stroke (width 0.12) (type default) (color 0 0 0 0))
    (fill (type none))
    (effects (font (size 1.05 1.05)))
    (uuid 9cf29b90-df07-5878-b6ca-798ceb060bc9)
  )
  (text_box "Panel is direct 3.3 V UART over the short Cat5e run: controller GPIO32 TX / GPIO33 RX."
    (at 14 398 0) (size 132 10)
    (stroke (width 0.12) (type default) (color 0 0 0 0))
    (fill (type none))
    (effects (font (size 1.05 1.05)))
    (uuid 46b0d550-f3d9-5cda-bcc9-54ad37414e1b)
  )

